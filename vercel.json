{
  "version": 2,

  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "api/index-template.html",
        "dist/**"
      ]
    }
  },

  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}