{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.ts": {
      "includeFiles": "{dist/**,api/index-template.html}"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(sw.js|manifest.json|favicon.ico|favicon.png|icon-192.png|icon-512.png|icon-maskable.png|apple-touch-icon.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/api/index?__vercel_original_path=/assets/:path*"
    },
    {
      "source": "/favicon.ico",
      "destination": "/api/index?__vercel_original_path=/favicon.ico"
    },
    {
      "source": "/favicon.png",
      "destination": "/api/index?__vercel_original_path=/favicon.png"
    },
    {
      "source": "/manifest.json",
      "destination": "/api/index?__vercel_original_path=/manifest.json"
    },
    {
      "source": "/sw.js",
      "destination": "/api/index?__vercel_original_path=/sw.js"
    },
    {
      "source": "/apple-touch-icon.png",
      "destination": "/api/index?__vercel_original_path=/apple-touch-icon.png"
    },
    {
      "source": "/default-news.jpg",
      "destination": "/api/index?__vercel_original_path=/default-news.jpg"
    },
    {
      "source": "/default-share.jpg",
      "destination": "/api/index?__vercel_original_path=/default-share.jpg"
    },
    {
      "source": "/logo.jpg",
      "destination": "/api/index?__vercel_original_path=/logo.jpg"
    },
    {
      "source": "/icon-192.png",
      "destination": "/api/index?__vercel_original_path=/icon-192.png"
    },
    {
      "source": "/icon-512.png",
      "destination": "/api/index?__vercel_original_path=/icon-512.png"
    },
    {
      "source": "/icon-maskable.png",
      "destination": "/api/index?__vercel_original_path=/icon-maskable.png"
    },
    {
      "source": "/api/news/digest",
      "destination": "/api/index?__vercel_original_path=/api/news/digest"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index?__vercel_original_path=/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/index?__vercel_original_path=/sitemap.xml"
    },
    {
      "source": "/google:hash.html",
      "destination": "/api/index?hash=:hash&__vercel_original_path=/google:hash.html"
    },
    {
      "source": "/uploads/:filename",
      "destination": "/api/index?filename=:filename&__vercel_original_path=/uploads/:filename"
    },
    {
      "source": "/artikel/:slug",
      "destination": "/api/index?__vercel_original_path=/artikel/:slug"
    },
    {
      "source": "/berita/:slug",
      "destination": "/api/index?__vercel_original_path=/berita/:slug"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index?__vercel_original_path=/api/:path*"
    },
    {
      "source": "/((?!api|assets|src|.*\\..*).*)",
      "destination": "/api/index"
    }
  ]
}
