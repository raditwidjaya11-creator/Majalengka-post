{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "dist/**",
        "api/index-template.html"
      ]
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(sw.js|manifest.json|favicon.ico|favicon.png|icon-192.png|icon-512.png|icon-maskable.png|apple-touch-icon.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/news/digest",
      "destination": "/api/index"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/index"
    },
    {
      "source": "/google:hash.html",
      "destination": "/api/index?hash=:hash"
    },
    {
      "source": "/uploads/:filename",
      "destination": "/api/index?filename=:filename"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api|assets|src|.*\\..*).*)",
      "destination": "/api/index"
    }
  ]
}
